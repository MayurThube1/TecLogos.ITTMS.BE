--- a/TecLogos.ITTMS.API/Program.cs
+++ b/TecLogos.ITTMS.API/Program.cs
@@
-            app.UseAuthorization();
-
-            app.MapControllers();
-
-            app.Run();
+            app.UseAuthorization();
+
+            try
+            {
+                app.MapControllers();
+            }
+            catch (System.Reflection.ReflectionTypeLoadException ex)
+            {
+                // Print loader exceptions to console to diagnose which types/assemblies failed to load
+                foreach (var le in ex.LoaderExceptions)
+                {
+                    Console.WriteLine(le.ToString());
+                }
+                // Print the Types array; failed entries will be null
+                foreach (var t in ex.Types ?? System.Array.Empty<System.Type>())
+                {
+                    Console.WriteLine(t?.FullName ?? "<null>");
+                }
+                throw;
+            }
+
+            app.Run();
+
+/*
+Instructions:
+- Save this patch file and apply it manually, or open Program.cs and replace the existing
+  app.MapControllers() call (and the surrounding lines shown above) with the try/catch block.
+- Rebuild and run the app. The console will print the LoaderExceptions which indicate the
+  actual root cause (missing dependency, type initializer failure, assembly mismatch, etc.).
+*/
